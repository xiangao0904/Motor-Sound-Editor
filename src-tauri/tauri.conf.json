{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Motor Sound Editor",
  "version": "1.0.0",
  "identifier": "com.hp.motor-sound-editor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Motor Sound Editor",
        "width": 1376,
        "height": 768,
        "minWidth": 880,
        "minHeight": 620,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["icons/file-ico.ico"],
    "fileAssociations": [
      {
        "ext": ["msep"],
        "name": "Motor Sound Editor Project",
        "description": "Motor Sound Editor Project",
        "role": "Editor",
        "mimeType": "application/x-motor-sound-editor-project",
        "rank": "Owner",
        "exportedType": {
          "identifier": "com.hp.motor-sound-editor.project",
          "conformsTo": ["public.data"]
        }
      }
    ],

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  }
}
